# nim-check: skip
#
# Reprobuild home profile for the zahary Windows development host.
# ---------------------------------------------------------------------------
# This file is the Reprobuild "intent layer": a declarative description of
# the elevation-free portion of this machine's environment. It is added
# ALONGSIDE the existing Nix-flake dotfiles and `bin/home-switch.ps1`
# Windows workflow -- nothing else in this repository is moved, deleted, or
# rewritten. `repro home apply` reads this file, realizes the packages
# through Scoop, materializes the `stow/` tree, and writes the managed
# blocks / registry contributions declared below.
#
# Authored for milestone M70 (Real ~/dotfiles Replacement E2E) and extended
# for M78 (Profile-Declared Home Resources). It is the ONLY file Reprobuild
# authors inside this repository; the structural editor (`repro home set` /
# `repro home add`) edits this file in place.
#
# M83 Phase F3 migration: built via the Phase A `repro_profile` macro
# library so `repro home apply` takes the compile-then-apply path
# end-to-end (Phase F3 made that the ONLY apply path -- the legacy text
# parser no longer fires as an auto-fallback). Hyphenated package
# identifiers (e.g. `windows-terminal`, `claude-code`) are spelled
# with backticks so the Nim parser accepts them; the structural
# editor's Phase F3 read-side update accepts both the bare and the
# backtick-quoted form. `when defined(windows):` compile-time guards
# replace the legacy parser's runtime `when windows:` shape inside the
# `resources:` block; activity-body predicates use the Phase A
# `windows()` predicate-function form.
#
# DELIBERATELY OUT OF SCOPE (left for a later milestone):
#   * OpenSSH server install + sshd service config  -> system scope (M69)
#   * GPG secret / age-identity decryption + import -> system scope / future
#   * Windows Developer-Mode enablement (the HKLM AppModelUnlock registry
#     flags) -> requires elevation, system scope
#   * 7zip is a transitive Scoop dependency, not a user-chosen package, so
#     it is intentionally NOT listed below (see the activity comment).
# `home-switch.ps1` continues to own those concerns until they are ported.

import repro_profile

profile "zahary":

  # The `default` activity is always enabled on every host. It carries the
  # user-facing Scoop packages that `home-switch.ps1` installs. They are
  # guarded by `when windows():` because this profile currently only
  # describes the Windows host; the same package set on Linux/macOS is
  # still owned by the Nix flake.
  activity default:
    when windows():
      # --- secrets / crypto tooling ---
      age              # extras bucket -- age encryption CLI
      gnupg            # main bucket   -- GnuPG

      # --- version control ---
      git              # main bucket
      gh               # main bucket   -- GitHub CLI

      # --- terminal / editor ---
      `windows-terminal` # extras bucket
      vscode           # extras bucket
      neovim           # main bucket

      # --- shells / environment ---
      pwsh             # main bucket   -- PowerShell 7
      direnv           # main bucket   -- per-directory env loader

      # --- search ---
      ripgrep          # main bucket   -- fast grep

      # --- browsers ---
      firefox          # extras bucket
      googlechrome     # extras bucket

      # --- AI dev tooling ---
      codex            # main bucket   -- OpenAI Codex CLI
      `claude-code`    # main bucket   -- Anthropic Claude Code CLI

  # Per-package configuration overrides. These feed the Configurable
  # system at priority `prSet`. The git identity values are mirrored from
  # the user's live `~/.gitconfig` (`stow/git/.gitconfig`).
  config:
    git:
      userName = "Zahary Karadjov"
      userEmail = "zahary@gmail.com"

  # ---------------------------------------------------------------------------
  # resources: -- M78 profile-declared home-scope resources.
  # ---------------------------------------------------------------------------
  # This block ports the ELEVATION-FREE affordances of `home-switch.ps1`
  # that previously had no representation in `home.nim`. Phase A
  # constructors (`envUserPath`, `shellIntegration`, `envUserVariable`)
  # produce one `ResourceIntent` each; `repro home apply` materializes
  # them through the M68 drivers and records one `ResourceBinding` per
  # resource in the activation manifest.
  #
  # Everything here is Windows-specific (PowerShell profile, the user
  # PATH registry value, HKCU\Environment variables), so the whole block
  # is wrapped in a `when defined(windows):` compile-time guard -- on a
  # non-Windows host none of these resources is planned or materialized.
  #
  # CO-RESIDENCE WITH home-switch.ps1: these resources are ADDITIVE. The
  # legacy script's `Ensure-PowerShellProfileDirenvHook` still writes its
  # own versioned `# BEGIN DOTFILES DIRENV v2` block to the PowerShell
  # profile, and its `Ensure-GitBashInPath` / `Ensure-DirenvConfig` still
  # touch the user PATH and the XDG env vars. The Reprobuild-managed
  # block below uses its OWN `repro-managed:` sentinels and its own
  # `env.userPath` contribution accounting, so the two coexist without
  # conflict. Once the user is satisfied that Reprobuild owns these
  # affordances, they retire the legacy `# BEGIN DOTFILES DIRENV` block
  # from `home-switch.ps1` BY HAND -- Reprobuild never edits or deletes
  # the legacy script.
  resources:
    when defined(windows):
      # 1. Put Reprobuild's realized-launcher directory on the user PATH.
      #    The literal `%LOCALAPPDATA%\...` form is host/user-portable;
      #    the M68 `env.userPath` driver preserves REG_EXPAND_SZ on the
      #    existing registry value so Windows expands the placeholders
      #    at session start.
      envUserPath(
        entries = "%LOCALAPPDATA%\\repro\\home\\bin," &
                  "%USERPROFILE%\\scoop\\apps\\git\\current\\usr\\bin",
        address = "launcherBin")

      # 2. PowerShell-profile shell integration: a Reprobuild-managed
      #    block in the PowerShell 7 profile carrying the XDG
      #    base-directory setup and the direnv `cd`-hook. `hostFile` is
      #    `~`-relative; the M68 `shell.integration` driver is purpose-
      #    built for a managed block in a shell startup file.
      shellIntegration(
        hostFile = "~/Documents/PowerShell/Microsoft.PowerShell_profile.ps1",
        blockId = "repro-home-direnv",
        content = "if (-not $env:XDG_CONFIG_HOME) { $env:XDG_CONFIG_HOME = $env:APPDATA }; if (-not $env:XDG_CACHE_HOME) { $env:XDG_CACHE_HOME = $env:LOCALAPPDATA }; if (-not $env:XDG_DATA_HOME) { $env:XDG_DATA_HOME = (Join-Path $env:LOCALAPPDATA 'direnv-data') }; if (-not $env:DIRENV_CONFIG) { $env:DIRENV_CONFIG = (Join-Path $env:XDG_CONFIG_HOME 'direnv') }; foreach ($d in @($env:XDG_CONFIG_HOME, $env:XDG_CACHE_HOME, $env:XDG_DATA_HOME, $env:DIRENV_CONFIG)) { if ($d -and -not (Test-Path $d)) { New-Item -ItemType Directory -Path $d -Force | Out-Null } }; if (Get-Command direnv -ErrorAction SilentlyContinue) { Invoke-Expression (& direnv hook pwsh | Out-String) }",
        address = "powershellProfileDirenv")

      # 3. The XDG base-directory variables as PERSISTENT user environment
      #    variables. `home-switch.ps1`'s `Ensure-DirenvConfig` sets these
      #    with `[Environment]::SetEnvironmentVariable(..., 'User')` -- i.e.
      #    they ARE persistent registry-backed user env vars.
      envUserVariable(name = "XDG_CONFIG_HOME",
        value = "%APPDATA%",
        valueKind = "expandString",
        address = "xdgConfigHome")

      envUserVariable(name = "XDG_CACHE_HOME",
        value = "%LOCALAPPDATA%",
        valueKind = "expandString",
        address = "xdgCacheHome")

      envUserVariable(name = "XDG_DATA_HOME",
        value = "%LOCALAPPDATA%\\direnv-data",
        valueKind = "expandString",
        address = "xdgDataHome")

      envUserVariable(name = "DIRENV_CONFIG",
        value = "%APPDATA%\\direnv",
        valueKind = "expandString",
        address = "direnvConfig")

  # Host -> activity map. `default` is always enabled regardless of this
  # block; the entry below documents the mapping for the real development
  # host explicitly (resolved host identity: `eli-pc`).
  hosts:
    "eli-pc": [default]

# ---------------------------------------------------------------------------
# stow/ auto-discovery
# ---------------------------------------------------------------------------
# This profile directory contains a `stow/` subtree (git, ssh, vim, nvim,
# jj, kitty, ghostty, zsh, tmux, zellij, windows-terminal, ai-agents,
# shell-helpers, hammerspoon, nix). Reprobuild's apply planner walks
# `stow/` automatically and materializes every regular file at the
# corresponding path under $HOME -- no hand-listing is required here. The
# `stow/` tree is hand-authored and is NOT modified by Reprobuild.
