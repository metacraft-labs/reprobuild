# Cross-repo siblings the dev-shell CI jobs (lint, test) clone adjacent to this
# checkout so config.nims's sibling detection can resolve them. The shared
# `clone-siblings` action (run by setup-dev-env) reads this file.
#
# `name=ref` clones the ref directly; plain `name` resolves the revision from
# the per-commit workspace lock in metacraft-manifests. reprobuild is not yet
# integrated into the lock contract, so pin the mainline branch explicitly.
#
# These carry codetracer's canonical incremental test engine
# (src/ct_test/incremental) and the trace-format-nim CTFS reader it imports,
# reached through ct_incremental_adapter (the engine-free seam). One-way
# dependency: reprobuild -> codetracer.
codetracer=deps/retire-nim-result-fork
codetracer-trace-format-nim=dev

# codetracer's `ct` binary (built via codetracer/reprobuild.nim's `ct` target so
# ct_incremental_adapter can exec `ct test --incremental`) imports the IsoNim UI
# stack and the shared Nim agent libs, so its Nim compile needs these adjacent on
# the --path. Pinned to mainline; reprobuild only ever execs the resulting `ct`.
isonim=dev
isonim-gpui=dev
isonim-tui=dev
nim-acp=dev
nim-agent-harbor=dev
nim-agents=dev
nim-everywhere=dev
nim-pty=dev
nim-termctl=dev

# The TestRunner cross-cutting contract (Nim package `repro_test_adapters`)
# lives in this standalone repo; `repro_dsl_stdlib` re-exports it, so the
# recipe-interface extractor that reads codetracer/reprobuild.nim needs it on
# the --path as `../reprobuild-test-adapters/src`. Mainline branch is `main`.
reprobuild-test-adapters=main
