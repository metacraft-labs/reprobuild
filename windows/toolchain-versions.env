# Pinned tool versions for the metacraft Windows dev environment.
# Shared install root: WINDOWS_DIY_INSTALL_ROOT (default D:\metacraft-dev-deps)

# M2 reconciliation (2026-05-31): JUST/GH/MAVEN pins bumped to catalog HEAD
# per the M2 decision table (bump where the pin had no fixture
# dependency and no behavioural break is expected). GRADLE/ZIG stayed
# on the existing pin and the catalog grew an extra slice via the M66
# harvester (gradle: 8.x LTS preservation; zig: M44 fixture pin to
# 0.13.0). SWIFT is an M70-deferred-8 tool whose migrator outcome is
# "TODO" regardless of the catalog slice set, so M2 left its env.ps1
# pin as-is — the canonical M2 reconciliation closure lives in M3-M5
# (cakBuiltin realize-time hooks).
#
# JUST/GH/PYTHON/GIT_REPO pins live in repo-workspaces/windows/toolchain-
# versions.env now (the framework env.ps1 owns those installs).
VULKAN_HEADERS_VERSION=1.3.296.0
MESA_VERSION=24.3.4
# M49: JDK + Maven (Adoptium Temurin LTS + Apache Maven 3.9.x)
JDK_VERSION=21.0.5
JDK_BUILD=11
MAVEN_VERSION=3.9.16
# M50: Gradle 8.x (JDK 21 from M49 is a hard runtime prerequisite).
# M2 left the env.ps1 pin at 8.10.2 (Gradle 8.x LTS); the catalog
# carries 9.5.1 as HEAD and 8.10.2 as the M2 backfilled slice so
# operators on a migrated home.nim resolve cleanly without forcing a
# major-version bump.
GRADLE_VERSION=8.10.2
# M51: Swift toolchain (swift.org Windows installer)
SWIFT_VERSION=5.10.1
# M52: OCaml + Dune. OCaml ships via MSYS2's mingw64 pacman package
# (``mingw-w64-x86_64-ocaml``); MSYS2 does not package dune, so
# ensure-ocaml.ps1 bootstraps it from the upstream source tarball
# (``ocaml boot/bootstrap.ml`` against github.com/ocaml/dune/releases).
# No version pin on ocaml itself — MSYS2 ships current stable
# (5.x as of 2026); dune is pinned to 3.23.1 inside ensure-ocaml.ps1.
# M53: Zig 0.13.0 (pre-1.0 pin — bumps require M44 fixture audit)
ZIG_VERSION=0.13.0
# M71: Go toolchain. Drives the reprobuild tests that shell out to
# ``go`` (cmake build_test_helper + the m9 sibling-build flows). Pin
# is a current 1.23.x — bumps within the same minor are safe.
GO_VERSION=1.23.4
# Free Pascal Compiler. Required by the pascal/sudoku_solver fixture
# in _lang_survey/run.sh (and the MCR cascade peeler tests that build
# on top of it). FPC ships as a single Inno Setup installer that
# bundles both the i386 host compiler (ppc386) and the x86_64 cross
# compiler (ppcrossx64) — both live under bin/i386-win32/; the driver
# (``fpc.exe``) picks the right backend via ``-P<cpu>``. Pin to the
# 3.2.2 release; bumps require re-validating the survey fixture.
FPC_VERSION=3.2.2
