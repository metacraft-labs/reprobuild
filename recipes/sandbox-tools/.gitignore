# reprobuild build scratch + outputs (regenerated by `repro build` +
# `assemble-bundle.sh`; never committed). Only the recipe sources, the shared
# Mode B template, the assembler, the test, and the vendored upstream tarballs
# under */vendor/ are tracked.
.repro/
*/build/
bundle/
# Stray extracted source trees (the fetch action extracts the tarball into
# */src/ at build time).
*/src/
# Compiled test binary (nim c -r leaves the executable next to the .nim).
test_sandbox_tools
