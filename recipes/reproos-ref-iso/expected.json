{
  "backend": "wsl2",
  "image": "vendor/debian-bookworm-slim-amd64-rootfs.tar.gz",
  "image_sha256": "b9136609bef0128191aa157637b98dd7b98e52154ca60c18258d65957a01c6d0",
  "evidence_type": "vendored-upstream-binary",
  "upstream": "https://hub.docker.com/_/debian",
  "builder_ref": "https://github.com/debuerreotype/docker-debian-artifacts",
  "post_import_setup": [
    "apt-get update",
    "apt-get install -y --no-install-recommends systemd dbus systemd-sysv",
    "printf '%s\\n' '[boot]' 'systemd=true' > /etc/wsl.conf"
  ],
  "assertions": [
    {
      "description": "systemd reports its version (systemd is installed and reachable)",
      "expect_line": "systemd 2\\d\\d",
      "timeout_s": 30,
      "send_before": "systemctl --version | head -1\n"
    },
    {
      "description": "system-state reflects PID-1 systemd (running, degraded, or starting)",
      "expect_line": "^(running|degraded|starting|initializing)$",
      "timeout_s": 60,
      "send_before": "systemctl is-system-running\n"
    }
  ]
}
