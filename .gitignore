.direnv/
result
result-*

build/
nimcache/
htmldocs/
*.nimble-link

# Standard-provider scratch path. ``ScratchDirName = ".repro/build"`` in
# libs/repro_standard_provider; if anyone runs the Nim convention against
# an in-tree fixture under this repo, the resulting ``.repro/`` tree
# would otherwise show up as untracked noise.
.repro/

# Stray in-place `nim c` build artifacts (smoke tests / apps compiled
# outside build/ during local iteration).
*.exe

test-logs/
repomix/
bench-results/

# Workspace-managed reference checkouts.
references/*
!references/README.md

.DS_Store

# Symlink to Nix-store pre-commit config; generated by direnv, never tracked.
.pre-commit-config.yaml

# Node-managed scratch (some prettier/markdown tooling pulls this in).
/node_modules

# Nim test binaries compiled in-place beside their .nim source (no extension
# on Mach-O / ELF). Pattern matches t_* and run_* binaries under tests/ and
# libs/**/tests/, with !-rules to whitelist the .nim sources, .md notes,
# and the .meta.json fixture sidecars.
tests/**/t_*
!tests/**/t_*.nim
!tests/**/t_*.md
!tests/**/t_*.meta.json
tests/**/run_*
!tests/**/run_*.nim
!tests/**/run_*.md
libs/**/tests/t_*
!libs/**/tests/t_*.nim
!libs/**/tests/t_*.md
