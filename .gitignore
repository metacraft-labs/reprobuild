.direnv/
result
result-*

build/
nimcache/
htmldocs/
*.nimble-link

# Standard-provider scratch path. ``ScratchDirName = ".repro/build"`` in
# libs/repro_standard_provider; if anyone runs the Nim convention against
# an in-tree fixture under this repo, the resulting ``.repro/`` tree
# would otherwise show up as untracked noise.
.repro/

# Stray in-place `nim c` build artifacts (smoke tests / apps compiled
# outside build/ during local iteration).
*.exe

# Nim test binaries produced by `nim c -r` next to the `.nim` source.
# Matches any extension-less sibling of a tests/*.nim file.
libs/*/tests/t_*
!libs/*/tests/t_*.nim
!libs/*/tests/t_*.nims
!libs/*/tests/t_*.cfg

# Stray Nim build artifacts dropped beside library source files when an
# implementation module is compiled directly with `nim c` (e.g. `nim c
# auth.nim` produces a `./auth` binary next to `auth.nim`). The pattern
# excludes every file under libs/*/src/ then re-allows the source-file
# extensions so the genuine Nim sources stay tracked.
libs/*/src/**/*
!libs/*/src/**/
!libs/*/src/**/*.nim
!libs/*/src/**/*.nims
!libs/*/src/**/*.cfg

# Same pattern for app entry points compiled in-place during local
# iteration (e.g. `nim c apps/repro-peer-cache-sim/repro_peer_cache_sim.nim`).
apps/*/repro_peer_cache_*
!apps/*/repro_peer_cache_*.nim
!apps/*/repro_peer_cache_*.nims
!apps/*/repro_peer_cache_*.cfg

test-logs/
repomix/
bench-results/

# Workspace-managed reference checkouts.
references/*
!references/README.md

.DS_Store
build/m4-live-smoke/

# Python bytecode caches from unittest runners
__pycache__/
*.pyc

# Boot-harness (R0) per-run JSON outcomes + serial logs.
# All transient VM/distro state goes to $env:TEMP\repro-boot-harness\;
# only the JSON outcome records land under the repo, here.
boot-harness-out/
*.vhdx

# R1 vendored upstream blobs — pulled by recipes/reproos-ref-iso/vendor/fetch.ps1
# on first run, never committed. The manifest, SHA256SUMS, and fetch
# script ARE committed; the blobs themselves are gitignored.
recipes/reproos-ref-iso/vendor/*.tar.gz
recipes/reproos-ref-iso/vendor/*.tar.xz
recipes/reproos-ref-iso/vendor/*.qcow2
recipes/reproos-ref-iso/vendor/*.raw
