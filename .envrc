# shellcheck shell=bash
# flake-overrides plugin (blocksense-network/direnv-nix-flake-overrides):
# prefer a sibling checkout of the plugin (workspace dev — always current),
# else the pinned published copy (CI / standalone clones).
_fo_local="../direnv-nix-flake-overrides/plugin/flake-overrides.bash"
if [[ -f "$_fo_local" ]]; then
	watch_file "$_fo_local"
	source "$_fo_local"
else
	source_url "https://direnv-flake-overrides.blocksense.network/plugin" \
		"sha256-BTxlsheP/7/FQw9IBPGFc6zYTl5S2qdAAt3EUqfkbjI="
fi
unset _fo_local

dotenv_if_exists .env
watch_file .env

# Full-auto local overrides: every flake input that has a same-named sibling
# checkout next to this repo is overridden to that checkout (honouring the
# metacraft `-src` suffix convention, e.g. runquota-src → ../runquota,
# ct-test-src → ../ct-test). The flake then builds the client AND the runquotad
# daemon from the local source. Pin or exclude an input by hand in .env via
# NIX_FLAKE_OVERRIDE_INPUTS if needed.
export NIX_FLAKE_OVERRIDE_AUTO=1
export NIX_FLAKE_OVERRIDE_AUTO_STRIP_SUFFIXES=-src
eval "use flake '.?submodules=1' $(flake_override_args_quoted)"
