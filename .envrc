# shellcheck shell=bash
# Auto-detect sibling repos and pass --override-input so the dev shell builds
# against local checkouts instead of the flake-pinned inputs. This covers both
# the client sources (RUNQUOTA_SRC / CT_TEST_SRC) AND the runquotad daemon the
# flake now provides from runquota-src — so you can iterate on a sibling (fix
# runquota, ct-test, …) without pushing and bumping the pin. Map entries are
# ``<sibling-dir>:<flake-input>``.
_rb_override_flags=""
_rb_sibling_map=(
	"runquota:runquota-src"
	"ct-test:ct-test-src"
	"codetracer-native-recorder:codetracer-native-recorder"
)
for _entry in "${_rb_sibling_map[@]}"; do
	_dir="${_entry%%:*}"
	_input="${_entry#*:}"
	if [[ -d "../$_dir" ]]; then
		_rb_override_flags+=" --override-input $_input path:../$_dir"
	fi
done
use flake ".?submodules=1${_rb_override_flags}"
unset _rb_override_flags _rb_sibling_map _entry _dir _input
